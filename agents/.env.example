# The Forge. Copy this to agents/.env and fill in your keys.

# Required: FAL.ai key for Pixelsmith (sprite generation).
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# All LLM work runs through your IDE's Claude session via the forge skill,
# so no separate API key is needed for the MCP server itself.

# Optional: override tModLoader ModSources directory.
# Defaults to the OS-standard tModLoader path. See README for resolution order.
# FORGE_MOD_SOURCES_DIR=

# Optional: override tModLoader install path (rare).
# TMODLOADER_PATH=
