<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>ForgeConnector</AssemblyName>
    <RootNamespace>ForgeConnector</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TModLoaderPath Condition="'$(TMODLOADER_PATH)' != ''">$(TMODLOADER_PATH)</TModLoaderPath>
    <TModLoaderPath Condition="'$(TModLoaderPath)' == ''">$(HOME)/Library/Application Support/Steam/steamapps/common/tModLoader</TModLoaderPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="tModLoader">
      <HintPath>$(TModLoaderPath)/tModLoader.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="FNA">
      <HintPath>$(TModLoaderPath)/Libraries/FNA/1.0.0/FNA.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="ReLogic">
      <HintPath>$(TModLoaderPath)/Libraries/ReLogic/1.0.0/ReLogic.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="log4net">
      <HintPath>$(TModLoaderPath)/Libraries/log4net/2.0.8.0/log4net.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
